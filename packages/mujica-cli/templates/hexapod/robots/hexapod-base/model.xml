      </body>
    </body>
  </worldbody>
  <!-- MUJICA_COMPONENTS -->
  <actuator>
    <motor name="hip-fl-motor" joint="hip-fl"/><motor name="knee-fl-motor" joint="knee-fl"/>
    <motor name="hip-fr-motor" joint="hip-fr"/><motor name="knee-fr-motor" joint="knee-fr"/>
    <motor name="hip-ml-motor" joint="hip-ml"/><motor name="knee-ml-motor" joint="knee-ml"/>
    <motor name="hip-mr-motor" joint="hip-mr"/><motor name="knee-mr-motor" joint="knee-mr"/>
    <motor name="hip-rl-motor" joint="hip-rl"/><motor name="knee-rl-motor" joint="knee-rl"/>
    <motor name="hip-rr-motor" joint="hip-rr"/><motor name="knee-rr-motor" joint="knee-rr"/>
  </actuator>
  <sensor>
    <touch name="foot-force-fl" site="foot-fl-site"/><touch name="foot-force-fr" site="foot-fr-site"/>
    <touch name="foot-force-ml" site="foot-ml-site"/><touch name="foot-force-mr" site="foot-mr-site"/>
    <touch name="foot-force-rl" site="foot-rl-site"/><touch name="foot-force-rr" site="foot-rr-site"/>
  </sensor>
  <keyframe>
    <key name="home" qpos="0 0 0.38 1 0 0 0 0 -0.55 0 -0.55 0 -0.55 0 -0.55 0 -0.55 0 -0.55"/>
  </keyframe>
</mujoco>
<!-- MUJICA_END -->
