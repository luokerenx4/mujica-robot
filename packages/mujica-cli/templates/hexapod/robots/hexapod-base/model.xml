<mujoco model="mujica-hexapod">
  <compiler angle="radian" autolimits="true"/>
  <option timestep="0.002" gravity="0 0 -9.81" integrator="RK4"/>
  <default>
    <joint damping="0.4" armature="0.018" limited="true"/>
    <geom friction="0.9 0.02 0.002" condim="3" solref="0.015 1"/>
    <motor ctrllimited="true" ctrlrange="-6 6"/>
  </default>
  <worldbody>
    <light pos="0 -1 3" dir="0 0 -1"/>
    <geom name="floor" type="plane" size="5 5 0.1" rgba="0.16 0.18 0.22 1"/>
    <body name="torso" pos="0 0 0.38">
      <freejoint name="root"/>
      <geom name="torso-geom" type="box" size="0.29 0.12 0.055" mass="4" rgba="0.48 0.30 0.72 1"/>

      <body name="leg-fl-upper" pos="0.24 0.13 0">
        <joint name="hip-fl" axis="0 1 0" range="-1.1 1.1"/>
        <geom type="capsule" fromto="0 0 0 0 0 -0.16" size="0.022" mass="0.15" rgba="0.75 0.70 0.86 1"/>
        <body name="leg-fl-lower" pos="0 0 -0.16">
          <joint name="knee-fl" axis="0 1 0" range="-1.8 0.3"/>
          <geom type="capsule" fromto="0 0 0 0 0 -0.16" size="0.020" mass="0.13" rgba="0.58 0.52 0.70 1"/>
          <geom name="foot-fl" type="sphere" pos="0 0 -0.17" size="0.032" mass="0.05" rgba="0.95 0.45 0.25 1"/>
          <site name="foot-fl-site" pos="0 0 -0.17" size="0.038" rgba="1 0.2 0.2 0.22"/>
        </body>
      </body>
      <body name="leg-fr-upper" pos="0.24 -0.13 0">
        <joint name="hip-fr" axis="0 1 0" range="-1.1 1.1"/>
        <geom type="capsule" fromto="0 0 0 0 0 -0.16" size="0.022" mass="0.15" rgba="0.75 0.70 0.86 1"/>
        <body name="leg-fr-lower" pos="0 0 -0.16">
          <joint name="knee-fr" axis="0 1 0" range="-1.8 0.3"/>
          <geom type="capsule" fromto="0 0 0 0 0 -0.16" size="0.020" mass="0.13" rgba="0.58 0.52 0.70 1"/>
          <geom name="foot-fr" type="sphere" pos="0 0 -0.17" size="0.032" mass="0.05" rgba="0.95 0.45 0.25 1"/>
          <site name="foot-fr-site" pos="0 0 -0.17" size="0.038" rgba="1 0.2 0.2 0.22"/>
        </body>
      </body>
      <body name="leg-ml-upper" pos="0 0.13 0">
        <joint name="hip-ml" axis="0 1 0" range="-1.1 1.1"/>
        <geom type="capsule" fromto="0 0 0 0 0 -0.16" size="0.022" mass="0.15" rgba="0.75 0.70 0.86 1"/>
        <body name="leg-ml-lower" pos="0 0 -0.16">
          <joint name="knee-ml" axis="0 1 0" range="-1.8 0.3"/>
          <geom type="capsule" fromto="0 0 0 0 0 -0.16" size="0.020" mass="0.13" rgba="0.58 0.52 0.70 1"/>
          <geom name="foot-ml" type="sphere" pos="0 0 -0.17" size="0.032" mass="0.05" rgba="0.95 0.45 0.25 1"/>
          <site name="foot-ml-site" pos="0 0 -0.17" size="0.038" rgba="1 0.2 0.2 0.22"/>
        </body>
      </body>
      <body name="leg-mr-upper" pos="0 -0.13 0">
        <joint name="hip-mr" axis="0 1 0" range="-1.1 1.1"/>
        <geom type="capsule" fromto="0 0 0 0 0 -0.16" size="0.022" mass="0.15" rgba="0.75 0.70 0.86 1"/>
        <body name="leg-mr-lower" pos="0 0 -0.16">
          <joint name="knee-mr" axis="0 1 0" range="-1.8 0.3"/>
