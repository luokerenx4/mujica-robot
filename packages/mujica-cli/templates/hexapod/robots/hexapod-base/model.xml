        </body>
      </body>
      <body name="leg-rl-upper" pos="-0.24 0.13 0">
        <joint name="hip-rl" axis="0 1 0" range="-1.1 1.1"/>
        <geom type="capsule" fromto="0 0 0 0 0 -0.16" size="0.022" mass="0.15" rgba="0.75 0.70 0.86 1"/>
        <body name="leg-rl-lower" pos="0 0 -0.16">
          <joint name="knee-rl" axis="0 1 0" range="-1.8 0.3"/>
          <geom type="capsule" fromto="0 0 0 0 0 -0.16" size="0.020" mass="0.13" rgba="0.58 0.52 0.70 1"/>
          <geom name="foot-rl" type="sphere" pos="0 0 -0.17" size="0.032" mass="0.05" rgba="0.95 0.45 0.25 1"/>
