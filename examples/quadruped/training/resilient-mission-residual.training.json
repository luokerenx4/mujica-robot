{
  "version": 1,
  "id": "resilient-mission-residual",
  "name": "Continuous mission residual PPO",
  "assembly": "resilient-command-conditioned-history-3dof",
  "trainer": "motion-quality-residual-ppo",
  "priorController": "behavior-supervisor",
  "domainProfile": "quadruped-resilient-mission-v1",
  "task": "resilient-forward-mission",
  "scenarios": [
    "mission-impact-left",
    "mission-impact-right"
  ],
  "totalSteps": 8192,
  "rolloutSteps": 256,
  "epochs": 2,
  "minibatchSize": 64,
  "learningRate": 0.00001,
  "gamma": 0.99,
  "gaeLambda": 0.95,
  "clipRatio": 0.15,
  "entropyCoefficient": 0,
  "residualScale": 0.02,
  "residualPenalty": 20,
  "qualityReward": {
    "jointAcceleration": 0.1,
    "bodyAngularAcceleration": 0.2,
    "actionSlew": 0.1,
    "actuatorSaturation": 0.2,
    "footSlip": 0.3,
    "footImpact": 0.2
  }
}
