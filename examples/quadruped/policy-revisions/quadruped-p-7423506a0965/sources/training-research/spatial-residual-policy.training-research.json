{
  "version": 1,
  "id": "spatial-residual-policy",
  "name": "Spatial residual policy autoresearch",
  "benchmark": "spatial-robustness",
  "training": "spatial-residual-locomotion",
  "controller": "spatial-residual-gait",
  "program": "SPATIAL_AUTOTRAIN.md",
  "seed": 42,
  "editable": {
    "path": "training/spatial-residual-locomotion.training.json",
    "parameters": [
      { "path": "/residualScale", "minimum": 0, "maximum": 1, "step": 0.25, "integer": false, "directionOrder": ["decrease", "increase"] },
      { "path": "/totalSteps", "minimum": 4096, "maximum": 16384, "step": 4096, "integer": true, "directionOrder": ["decrease", "increase"] },
      { "path": "/learningRate", "minimum": 0.0001, "maximum": 0.0005, "step": 0.0001, "integer": false, "directionOrder": ["decrease", "increase"] },
      { "path": "/entropyCoefficient", "minimum": 0, "maximum": 0.01, "step": 0.002, "integer": false, "directionOrder": ["decrease", "increase"] },
      { "path": "/epochs", "minimum": 2, "maximum": 6, "step": 2, "integer": true, "directionOrder": ["increase", "decrease"] },
      { "path": "/clipRatio", "minimum": 0.1, "maximum": 0.25, "step": 0.05, "integer": false, "directionOrder": ["decrease", "increase"] }
    ]
  },
  "minimumImprovement": 0.01,
  "maxIterations": 16
}
