{
  "version": 1,
  "id": "forward-gait",
  "name": "Symmetric force-aware forward bound",
  "kind": "program",
  "entry": "controller.py",
  "interface": {
    "requiredObservations": [
      { "name": "joint-position", "size": 8 },
      { "name": "joint-velocity", "size": 8 },
      { "name": "imu-angular-velocity", "size": 3 },
      { "name": "foot-contact-force", "size": 4 }
    ],
    "actionChannels": [
      { "name": "joint-torque", "size": 8, "low": -6, "high": 6 }
    ]
  },
  "config": {
    "kp": 32,
    "kd": 2,
    "frequencyHz": 1.2,
    "neutralHip": 0.29,
    "neutralKnee": -0.47,
    "hipAmplitude": 0.25,
    "kneeAmplitude": 0.04,
    "leftRightPhase": 0,
    "frontRearPhase": 3.141592653589793,
    "contactGain": 0.02,
    "rollGain": 0.02
  }
}
