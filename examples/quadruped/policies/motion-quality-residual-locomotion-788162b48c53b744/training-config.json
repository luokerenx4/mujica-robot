{
  "version": 1,
  "id": "motion-quality-residual-locomotion",
  "name": "Quality-aware upright residual locomotion",
  "assembly": "command-conditioned-history-3dof",
  "trainer": "motion-quality-residual-ppo",
  "task": "forward-walk",
  "scenarios": [
    "nominal",
    "actuator-delay-three-step"
  ],
  "priorController": "upright-traction-gait",
  "totalSteps": 4096,
  "rolloutSteps": 256,
  "epochs": 2,
  "minibatchSize": 64,
  "learningRate": 3e-05,
  "gamma": 0.99,
  "gaeLambda": 0.95,
  "clipRatio": 0.15,
  "entropyCoefficient": 0,
  "residualScale": 0.03,
  "residualPenalty": 5,
  "qualityReward": {
    "jointAcceleration": 0.2,
    "bodyAngularAcceleration": 0.5,
    "actionSlew": 0.3,
    "actuatorSaturation": 0.4,
    "footSlip": 0.8,
    "footImpact": 0.6
  }
}
