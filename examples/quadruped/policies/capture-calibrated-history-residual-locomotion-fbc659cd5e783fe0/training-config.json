{
  "version": 1,
  "id": "capture-calibrated-history-residual-locomotion",
  "name": "Plant-bound capture-calibrated history residual locomotion",
  "assembly": "force-sensing-history-3dof",
  "trainer": "capture-history-residual-ppo",
  "task": "forward-walk",
  "scenarios": [
    "nominal",
    "reset-perturbation",
    "low-friction",
    "strong-lateral-push",
    "actuator-delay"
  ],
  "priorController": "latency-aware-spatial-gait",
  "domainProfile": "quadruped-dry-run-capture-calibrated-v2",
  "totalSteps": 8192,
  "rolloutSteps": 512,
  "epochs": 2,
  "minibatchSize": 128,
  "learningRate": 5e-05,
  "gamma": 0.99,
  "gaeLambda": 0.95,
  "clipRatio": 0.15,
  "entropyCoefficient": 0,
  "residualScale": 0.01,
  "residualPenalty": 20,
  "qualityReward": {
    "jointAcceleration": 0,
    "bodyAngularAcceleration": 0.15,
    "actionSlew": 0,
    "actuatorSaturation": 0.5,
    "footSlip": 0,
    "footImpact": 0.4
  }
}
