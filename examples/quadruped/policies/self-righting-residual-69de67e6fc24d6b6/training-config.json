{
  "version": 1,
  "id": "self-righting-residual",
  "name": "Rigid-torso residual self-righting PPO",
  "assembly": "self-righting-rigid-3dof",
  "trainer": "motion-quality-residual-ppo",
  "task": "self-right",
  "scenarios": [
    "fallen-front",
    "fallen-back",
    "fallen-left",
    "fallen-right"
  ],
  "priorController": "rigid-self-right",
  "totalSteps": 8192,
  "rolloutSteps": 256,
  "epochs": 4,
  "minibatchSize": 64,
  "learningRate": 0.0003,
  "gamma": 0.99,
  "gaeLambda": 0.95,
  "clipRatio": 0.2,
  "entropyCoefficient": 0.002,
  "residualScale": 0.3,
  "residualPenalty": 0.02,
  "qualityReward": {
    "jointAcceleration": 0.001,
    "bodyAngularAcceleration": 0.002,
    "actionSlew": 0.001,
    "actuatorSaturation": 0.01,
    "footSlip": 0,
    "footImpact": 0
  }
}
