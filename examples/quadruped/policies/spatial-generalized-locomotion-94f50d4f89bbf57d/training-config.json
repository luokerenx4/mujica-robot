{
  "version": 1,
  "id": "spatial-generalized-locomotion",
  "name": "Delay-domain-randomized spatial residual policy",
  "assembly": "force-sensing-history-3dof",
  "trainer": "spatial-residual-ppo",
  "task": "forward-walk",
  "scenarios": [
    "nominal",
    "reset-perturbation",
    "low-friction",
    "payload-variation",
    "strong-lateral-push",
    "reverse-strong-lateral-push",
    "actuator-delay-one-step",
    "actuator-delay",
    "actuator-delay-three-step",
    "delayed-lateral-push",
    "delayed-reset-perturbation"
  ],
  "totalSteps": 16384,
  "rolloutSteps": 512,
  "epochs": 2,
  "minibatchSize": 128,
  "learningRate": 0.0002,
  "gamma": 0.99,
  "gaeLambda": 0.95,
  "clipRatio": 0.15,
  "entropyCoefficient": 0.002,
  "residualScale": 0.5
}
