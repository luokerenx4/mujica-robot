<mujoco model="mujica-quadruped-3dof">
  <compiler angle="radian" autolimits="true"/>
  <option timestep="0.002" gravity="0 0 -9.81" integrator="RK4"/>
  <default>
    <joint damping="0.4" armature="0.018" limited="true"/>
    <geom friction="0.9 0.02 0.002" condim="3" solref="0.015 1"/>
    <motor ctrllimited="true" ctrlrange="-8 8"/>
  </default>
  <worldbody>
    <light pos="0 -1 3" dir="0 0 -1"/>
    <geom name="floor" type="plane" size="5 5 0.1" rgba="0.18 0.2 0.24 1"/>
    <body name="torso" pos="0 0 0.44">
      <freejoint name="root"/>
      <geom name="torso-geom" type="box" size="0.25 0.15 0.06" mass="4" rgba="0.22 0.45 0.78 1"/>
      <site name="imu-site" pos="0 0 0.065" size="0.015" rgba="0.2 1 0.3 1"/>
      <site name="foot-array-site" pos="0 0 0" size="0.005" rgba="0 0 0 0"/>

      <body name="leg-fl-abductor" pos="0.20 0.14 0">
        <joint name="abd-fl" axis="1 0 0" range="-0.65 0.65"/>
        <geom type="sphere" size="0.035" mass="0.08" rgba="0.35 0.75 0.9 1"/>
        <body name="leg-fl-upper">
          <joint name="hip-fl" axis="0 1 0" range="-1.2 1.2"/>
          <geom type="capsule" fromto="0 0 0 0.04 0 -0.20" size="0.025" mass="0.18" rgba="0.75 0.75 0.78 1"/>
          <body name="leg-fl-lower" pos="0.04 0 -0.20">
            <joint name="knee-fl" axis="0 1 0" range="-2.2 0.1"/>
            <geom type="capsule" fromto="0 0 0 -0.04 0 -0.20" size="0.022" mass="0.16" rgba="0.55 0.58 0.64 1"/>
            <geom name="foot-fl" type="sphere" pos="-0.04 0 -0.21" size="0.035" mass="0.06" rgba="0.9 0.35 0.2 1"/>
            <site name="foot-fl-site" pos="-0.04 0 -0.21" size="0.04" rgba="1 0.2 0.2 0.25"/>
          </body>
        </body>
      </body>
      <body name="leg-fr-abductor" pos="0.20 -0.14 0">
        <joint name="abd-fr" axis="1 0 0" range="-0.65 0.65"/>
        <geom type="sphere" size="0.035" mass="0.08" rgba="0.35 0.75 0.9 1"/>
        <body name="leg-fr-upper">
          <joint name="hip-fr" axis="0 1 0" range="-1.2 1.2"/>
          <geom type="capsule" fromto="0 0 0 0.04 0 -0.20" size="0.025" mass="0.18" rgba="0.75 0.75 0.78 1"/>
          <body name="leg-fr-lower" pos="0.04 0 -0.20">
            <joint name="knee-fr" axis="0 1 0" range="-2.2 0.1"/>
            <geom type="capsule" fromto="0 0 0 -0.04 0 -0.20" size="0.022" mass="0.16" rgba="0.55 0.58 0.64 1"/>
            <geom name="foot-fr" type="sphere" pos="-0.04 0 -0.21" size="0.035" mass="0.06" rgba="0.9 0.35 0.2 1"/>
            <site name="foot-fr-site" pos="-0.04 0 -0.21" size="0.04" rgba="1 0.2 0.2 0.25"/>
          </body>
        </body>
      </body>
      <body name="leg-rl-abductor" pos="-0.20 0.14 0">
        <joint name="abd-rl" axis="1 0 0" range="-0.65 0.65"/>
        <geom type="sphere" size="0.035" mass="0.08" rgba="0.35 0.75 0.9 1"/>
        <body name="leg-rl-upper">
          <joint name="hip-rl" axis="0 1 0" range="-1.2 1.2"/>
          <geom type="capsule" fromto="0 0 0 -0.04 0 -0.20" size="0.025" mass="0.18" rgba="0.75 0.75 0.78 1"/>
          <body name="leg-rl-lower" pos="-0.04 0 -0.20">
            <joint name="knee-rl" axis="0 1 0" range="-2.2 0.1"/>
            <geom type="capsule" fromto="0 0 0 0.04 0 -0.20" size="0.022" mass="0.16" rgba="0.55 0.58 0.64 1"/>
            <geom name="foot-rl" type="sphere" pos="0.04 0 -0.21" size="0.035" mass="0.06" rgba="0.9 0.35 0.2 1"/>
            <site name="foot-rl-site" pos="0.04 0 -0.21" size="0.04" rgba="1 0.2 0.2 0.25"/>
          </body>
        </body>
      </body>
      <body name="leg-rr-abductor" pos="-0.20 -0.14 0">
        <joint name="abd-rr" axis="1 0 0" range="-0.65 0.65"/>
        <geom type="sphere" size="0.035" mass="0.08" rgba="0.35 0.75 0.9 1"/>
        <body name="leg-rr-upper">
          <joint name="hip-rr" axis="0 1 0" range="-1.2 1.2"/>
          <geom type="capsule" fromto="0 0 0 -0.04 0 -0.20" size="0.025" mass="0.18" rgba="0.75 0.75 0.78 1"/>
          <body name="leg-rr-lower" pos="-0.04 0 -0.20">
            <joint name="knee-rr" axis="0 1 0" range="-2.2 0.1"/>
            <geom type="capsule" fromto="0 0 0 0.04 0 -0.20" size="0.022" mass="0.16" rgba="0.55 0.58 0.64 1"/>
            <geom name="foot-rr" type="sphere" pos="0.04 0 -0.21" size="0.035" mass="0.06" rgba="0.9 0.35 0.2 1"/>
            <site name="foot-rr-site" pos="0.04 0 -0.21" size="0.04" rgba="1 0.2 0.2 0.25"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>
  <sensor>
  <gyro name="body-gyro" site="imu-site"/>
  <accelerometer name="body-accelerometer" site="imu-site"/>
</sensor>


<!-- Bounded actuator history is supplied by the Runtime and adds no MJCF elements. -->

<sensor>
  <touch name="foot-force-fl" site="foot-fl-site"/>
  <touch name="foot-force-fr" site="foot-fr-site"/>
  <touch name="foot-force-rl" site="foot-rl-site"/>
  <touch name="foot-force-rr" site="foot-rr-site"/>
</sensor>


  <actuator>
    <motor name="abd-fl-motor" joint="abd-fl"/><motor name="hip-fl-motor" joint="hip-fl"/><motor name="knee-fl-motor" joint="knee-fl"/>
    <motor name="abd-fr-motor" joint="abd-fr"/><motor name="hip-fr-motor" joint="hip-fr"/><motor name="knee-fr-motor" joint="knee-fr"/>
    <motor name="abd-rl-motor" joint="abd-rl"/><motor name="hip-rl-motor" joint="hip-rl"/><motor name="knee-rl-motor" joint="knee-rl"/>
    <motor name="abd-rr-motor" joint="abd-rr"/><motor name="hip-rr-motor" joint="hip-rr"/><motor name="knee-rr-motor" joint="knee-rr"/>
  </actuator>
  <keyframe>
    <key name="home" qpos="0 0 0.44 1 0 0 0 0.15 0.15 -0.75 -0.15 0.15 -0.75 0.15 0.15 -0.75 -0.15 0.15 -0.75"/>
  </keyframe>
</mujoco>
