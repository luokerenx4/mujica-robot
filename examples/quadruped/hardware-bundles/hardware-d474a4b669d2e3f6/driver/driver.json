{
  "version": 1,
  "id": "mujoco-protocol-simulator",
  "name": "MuJoCo stdio protocol simulator",
  "protocol": "stdio-jsonl-v1",
  "executable": "driver.py",
  "environments": ["dry-run"],
  "device": {
    "vendor": "Mujica",
    "model": "Protocol simulator"
  },
  "capabilities": [
    "applied-action",
    "command-lease",
    "decision-deadline",
    "device-health",
    "latched-stop-health",
    "shadow-action",
    "state-abi-v1",
    "state-age-ms",
    "stop-ack"
  ]
}
