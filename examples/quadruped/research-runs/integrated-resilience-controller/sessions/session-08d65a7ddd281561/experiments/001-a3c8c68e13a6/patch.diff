+    def stand_action(self, observation):
+        """Track the qualified standing pose without advancing recovery phases."""
+        q = np.asarray(observation["joint-position"], dtype=np.float64).reshape(4, 3)
+        qd = np.asarray(observation["joint-velocity"], dtype=np.float64).reshape(4, 3)
+        action = np.empty((4, 3), dtype=np.float64)
+        action[:, 0] = (
+            self.config["kpAbduction"] * (self.stand_target[:, 0] - q[:, 0])
+            - self.config["kdAbduction"] * qd[:, 0]
+        )
+        action[:, 1:] = (
+            self.config["kpSagittal"] * (self.stand_target[:, 1:] - q[:, 1:])
+            - self.config["kdSagittal"] * qd[:, 1:]
+        )
+        return np.clip(action.reshape(-1), -8.0, 8.0)
+
