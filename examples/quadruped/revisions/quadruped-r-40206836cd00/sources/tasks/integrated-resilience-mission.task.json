{
  "version": 7,
  "id": "integrated-resilience-mission",
  "name": "Walk, absorb impact, recover, redirect, traverse, and stop",
  "durationSeconds": 18,
  "controlHz": 50,
  "healthyHeight": [0.05, 0.8],
  "terminateOnFall": false,
  "motionCommandSchedule": [
    {
      "atSeconds": 0,
      "command": {
        "frame": "world",
        "linearVelocityMps": [0.2, 0],
        "yawRateRadPerSec": 0
      }
    },
    {
      "atSeconds": 8,
      "command": {
        "frame": "world",
        "linearVelocityMps": [0.2, 0],
        "yawRateRadPerSec": 0
      }
    },
    {
      "atSeconds": 10,
      "command": {
        "frame": "world",
        "linearVelocityMps": [0.12, 0],
        "yawRateRadPerSec": 0.25
      }
    },
    {
      "atSeconds": 13,
      "command": {
        "frame": "world",
        "linearVelocityMps": [0, 0.15],
        "yawRateRadPerSec": 0
      }
    },
    {
      "atSeconds": 16,
      "command": {
        "frame": "world",
        "linearVelocityMps": [0, 0],
        "yawRateRadPerSec": 0
      }
    }
  ],
  "missionPhases": [
    {
      "id": "approach",
      "name": "Approach under forward command",
      "atSeconds": 0,
      "intent": "operate",
      "requiredCapabilities": ["walking", "command-tracking"]
    },
    {
      "id": "impact",
      "name": "Bounded lateral impact while walking",
      "atSeconds": 2.5,
      "intent": "disturbance",
      "requiredCapabilities": ["impact-tolerance"]
    },
    {
      "id": "recover",
      "name": "Autonomous self-righting without reset",
      "atSeconds": 2.66,
      "intent": "recover",
      "requiredCapabilities": ["self-righting", "behavior-supervision"]
    },
    {
      "id": "resume",
      "name": "Resume the pending forward mission",
      "atSeconds": 8,
      "intent": "resume",
      "requiredCapabilities": ["mission-resumption", "command-tracking"]
    },
    {
      "id": "redirect",
      "name": "Track a combined forward and yaw command",
      "atSeconds": 10,
      "intent": "operate",
      "requiredCapabilities": ["yaw-tracking", "command-transition"]
    },
    {
      "id": "traverse",
      "name": "Redirect into lateral traversal",
      "atSeconds": 13,
      "intent": "operate",
      "requiredCapabilities": ["lateral-tracking", "command-transition"]
    },
    {
      "id": "stop",
      "name": "Brake and hold",
      "atSeconds": 16,
      "intent": "stop",
      "requiredCapabilities": ["controlled-stop"]
    }
  ],
  "recoveryEvaluationStartSeconds": 2.7,
  "mobilityMeasurementStartSeconds": 8,
  "recoveryTarget": {
    "minimumBaseHeightM": 0.32,
    "maximumBodyTiltRad": 0.35,
    "maximumLinearSpeedMps": 0.2,
    "maximumAngularSpeedRadPerSec": 0.5,
    "holdSeconds": 0.5
  }
}
